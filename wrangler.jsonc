{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "fomofeed",
  "compatibility_date": "2026-04-13",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "build": {
    "command": "cd web && bun install && bun run build"
  },
  "routes": [
    { "pattern": "feedfomo.f3l1x.app", "custom_domain": true }
  ]
}
