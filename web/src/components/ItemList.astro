---
---

<div>
  <!-- Item count -->
  <div class="mb-3 text-xs text-text-muted">
    <span x-text="filteredItems.length"></span> articles
    <template x-if="activeFeeds.size > 0">
      <span>
        from <span x-text="activeFeeds.size"></span> source<span x-show="activeFeeds.size > 1">s</span>
      </span>
    </template>
  </div>

  <!-- Items -->
  <div class="divide-y divide-border/50">
    <template x-for="item in paginatedItems" :key="item.link">
      <a
        :href="item.link"
        target="_blank"
        rel="noopener"
        class="group flex gap-4 px-2 py-3 transition-colors hover:bg-surface-2/50 sm:px-3"
      >
        <!-- Date -->
        <div
          class="hidden w-20 shrink-0 pt-0.5 text-right font-mono text-[0.7rem] tabular-nums text-text-muted sm:block"
          x-text="formatDate(item.date)"
        >
        </div>

        <!-- Content -->
        <div class="min-w-0 flex-1">
          <div class="flex items-start gap-2">
            <h3
              class="truncate text-sm font-medium text-text-primary transition-colors group-hover:text-white"
              x-text="item.title"
            >
            </h3>
          </div>

          <div class="mt-0.5 flex items-center gap-2">
            <span
              class="inline-block rounded border border-border bg-surface-1 px-1.5 py-px text-[0.65rem] text-text-muted"
              x-text="item.feedName"
            >
            </span>
            <span
              class="text-[0.65rem] text-text-muted sm:hidden"
              x-text="formatDate(item.date)"
            >
            </span>
          </div>

          <template x-if="item.description">
            <p
              class="mt-1 truncate text-xs text-text-secondary/70"
              x-text="item.description"
            >
            </p>
          </template>
        </div>

        <!-- Arrow -->
        <div class="hidden shrink-0 pt-1 text-text-muted/0 transition-colors group-hover:text-text-muted sm:block">
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M7 17L17 7M17 7H7M17 7v10"></path>
          </svg>
        </div>
      </a>
    </template>
  </div>

  <!-- Empty state -->
  <template x-if="filteredItems.length === 0 && !loading">
    <div class="py-16 text-center text-sm text-text-muted">
      No articles match your filters.
    </div>
  </template>

  <!-- Load more -->
  <template x-if="visibleCount < filteredItems.length">
    <div class="mt-4 text-center">
      <button
        @click="visibleCount += 50"
        class="rounded-lg border border-border bg-surface-1 px-5 py-2 text-xs font-medium text-text-secondary transition-all hover:border-border-hover hover:text-text-primary"
      >
        Show more
        <span class="text-text-muted">
          (<span x-text="filteredItems.length - visibleCount"></span> remaining)
        </span>
      </button>
    </div>
  </template>
</div>
