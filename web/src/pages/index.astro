---
import Layout from "../layouts/Layout.astro";
import SearchBar from "../components/SearchBar.astro";
import CategoryFilter from "../components/CategoryFilter.astro";
import FeedTags from "../components/FeedTags.astro";
import ItemList from "../components/ItemList.astro";
import feedsData from "../../../feeds/data.json";

type RawItem = {
  title: string;
  link: string;
  description?: string;
  date?: string | null;
};

type RawFeed = {
  id: string;
  name: string;
  url: string;
  category: string;
  company: string | null;
  items: RawItem[];
};

const feeds = (feedsData.feeds as RawFeed[]).map((f) => ({
  id: f.id,
  name: f.name,
  url: f.url,
  category: f.category,
  company: f.company ?? null,
  itemCount: f.items.length,
}));

const categories = [...new Set(feeds.map((f) => f.category))];

const items = (feedsData.feeds as RawFeed[])
  .flatMap((feed) =>
    feed.items.map((item) => ({
      title: item.title,
      link: item.link,
      description: item.description ?? "",
      date: item.date ?? null,
      feedId: feed.id,
      feedName: feed.name,
      category: feed.category,
    })),
  )
  .sort((a, b) => {
    if (!a.date && !b.date) return 0;
    if (!a.date) return 1;
    if (!b.date) return -1;
    return new Date(b.date).getTime() - new Date(a.date).getTime();
  });

const generated = feedsData.generated as string;
---

<Layout>
  <div
    class="mx-auto max-w-3xl px-4 py-8 sm:px-6 sm:py-12"
    x-data="feedApp()"
  >
    <header class="mb-8 text-center">
      <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        FomoFeed
      </h1>
      <p class="mt-1 text-sm text-text-secondary">
        RSS feeds for sites that don't have them
      </p>
      <p class="mt-3 text-xs">
        <a href="/feeds" class="text-accent-green hover:underline">Browse feed URLs →</a>
      </p>
    </header>

    <div class="space-y-5">
      <SearchBar />
      <CategoryFilter />
      <FeedTags />
      <ItemList />
    </div>

    <footer class="mt-10 border-t border-border/50 pt-6 text-center text-xs text-text-muted">
      {items.length} articles from {feeds.length} feeds &middot;
      updated <time datetime={generated}>{new Date(generated).toUTCString()}</time>
    </footer>
  </div>

  <script type="application/json" id="feed-data" set:html={JSON.stringify({ feeds, categories, items })} />

  <script>
    type FeedMeta = {
      id: string;
      name: string;
      url: string;
      category: string;
      company: string | null;
      itemCount: number;
    };
    type Item = {
      title: string;
      link: string;
      description: string;
      date: string | null;
      feedId: string;
      feedName: string;
      category: string;
    };

    const data = JSON.parse(document.getElementById("feed-data")!.textContent!) as {
      feeds: FeedMeta[];
      categories: string[];
      items: Item[];
    };

    document.addEventListener("alpine:init", () => {
      // @ts-ignore — Alpine global
      window.Alpine.data("feedApp", () => ({
        search: "",
        activeCategory: "all",
        activeFeeds: new Set<string>(),
        feeds: data.feeds,
        allItems: data.items,
        categories: data.categories,
        visibleCount: 50,

        get visibleFeeds() {
          if (this.activeCategory === "all") return this.feeds;
          return this.feeds.filter((f) => f.category === this.activeCategory);
        },

        get filteredItems() {
          const q = this.search.toLowerCase().trim();
          return this.allItems.filter((item) => {
            if (this.activeCategory !== "all" && item.category !== this.activeCategory) return false;
            if (this.activeFeeds.size > 0 && !this.activeFeeds.has(item.feedId)) return false;
            if (
              q &&
              !item.title.toLowerCase().includes(q) &&
              !item.description.toLowerCase().includes(q) &&
              !item.feedName.toLowerCase().includes(q)
            )
              return false;
            return true;
          });
        },

        get paginatedItems() {
          return this.filteredItems.slice(0, this.visibleCount);
        },

        toggleFeed(id: string) {
          if (this.activeFeeds.has(id)) this.activeFeeds.delete(id);
          else this.activeFeeds.add(id);
          this.activeFeeds = new Set(this.activeFeeds);
          this.visibleCount = 50;
        },

        capitalize(s: string) {
          return s.charAt(0).toUpperCase() + s.slice(1);
        },

        formatDate(iso: string | null) {
          if (!iso) return "";
          const d = new Date(iso);
          const diffDays = Math.floor((Date.now() - d.getTime()) / 86400000);
          if (diffDays === 0) return "Today";
          if (diffDays === 1) return "Yesterday";
          if (diffDays < 7) return `${diffDays}d ago`;
          if (diffDays < 365) return d.toLocaleDateString("en-US", { month: "short", day: "numeric" });
          return d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
        },
      }));
    });
  </script>
</Layout>
